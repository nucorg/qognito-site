---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Qognito.io | Professional Experience" lang="en">
  <!-- Title / Intro Section -->
  <section class="section section-intro">
    <div class="container intro-container">
      <div class="intro-flex">
        <div class="intro-text">
          <span class="monospace-label">Rigor & Deliverability</span>
          <h1 class="intro-title text-glow">Experience</h1>
          <p class="intro-subtitle">
            Over <strong>25 years of experience</strong> at the intersection of engineering, Data Science, and Artificial Intelligence. A career built in the most constrained environments — telecommunications, finance, international organizations, and nuclear energy.
          </p>
        </div>
        <div class="intro-photo-wrapper">
          <img src="/assets/PHOTO.jpg" alt="Boris Guarisma" class="profile-photo" />
        </div>
      </div>
    </div>
  </section>

  <!-- Professional Experience Timeline -->
  <section class="section section-experience">
    <div class="container experience-container">
      <h2 class="section-title text-glow">Professional Experience</h2>
      
      <div class="timeline">
        <!-- Qognito.io -->
        <div class="timeline-entry">
          <div class="timeline-logo">
            <img src="/assets/Qognito_lettre_entier.png" alt="Qognito.io" class="company-logo" />
          </div>
          <div class="timeline-content">
            <h3 class="experience-title">Founder & AI Consultant</h3>
            <div class="experience-meta">
              <strong>Qognito.io</strong> · <span class="timeline-date">July 2025 – Present · Puteaux (92), France</span>
            </div>
            <p class="experience-desc">
              Independent Data & AI consulting, specializing in scoping and prototyping under physical and regulatory constraints for critical enterprise systems.
            </p>
            
            <div class="mission-block">
              <strong class="mission-title">Main Mission — AI Technical Scoping Support:</strong>
              <span class="mission-subtitle">Multi-disciplinary product scoping team · a major player in the French nuclear sector</span>
              <ul class="experience-bullets">
                <li>Identification and prioritization of AI opportunities across <strong>4 business domains simultaneously</strong> (25+ opportunities evaluated)</li>
                <li>Formal feasibility studies: architecture, data governance, compliance (Export Control, EU AI Act, nuclear safety)</li>
                <li>Design of specialized AI architectures: Knowledge Graphs, physical models (PINNs, Kalman Filter), multi-scale e-monitoring, and LLM agents</li>
                <li>Prototyping (POC) and technical handover to delivery teams (phased blueprints POC → MVP → Pilot)</li>
                <li>AI acculturation of product teams: training, shifting paradigms from deterministic to probabilistic</li>
              </ul>
            </div>
            
            <div class="stack-block">
              <span class="monospace-label stack-label">Tech Stack:</span>
              <p class="stack-text">Mistral / Local LLMs, Neo4j, Dataiku DSS, Kafka, Apache Spark, Azure OpenAI</p>
            </div>
          </div>
        </div>

        <!-- Ippon Technologies -->
        <div class="timeline-entry">
          <div class="timeline-logo">
            <img src="/assets/logos/ippon.png" alt="Ippon Technologies" class="company-logo" />
          </div>
          <div class="timeline-content">
            <h3 class="experience-title">CTO Paris Branch</h3>
            <div class="experience-meta">
              <strong>Ippon Technologies</strong> · <span class="timeline-date">June 2024 – June 2025 · Paris, France</span>
            </div>
            <p class="experience-desc">
              Technical direction of the Paris branch of an IT consulting firm specializing in Data & AI.
            </p>
            <ul class="experience-bullets">
              <li>Steering the branch's commercial and technical strategy</li>
              <li>Managing senior managers and their technical teams</li>
              <li>Defining the vision and **quarterly OKRs of the AI Practice**</li>
              <li>Recruitment, onboarding, and retention of talents</li>
            </ul>
          </div>
        </div>

        <!-- Avanade -->
        <div class="timeline-entry">
          <div class="timeline-logo">
            <img src="/assets/logos/avanade.png" alt="Avanade" class="company-logo" />
          </div>
          <div class="timeline-content">
            <h3 class="experience-title">Practice Lead France — Artificial Intelligence</h3>
            <div class="experience-meta">
              <strong>Avanade</strong> <em>(JV Accenture × Microsoft)</em> · <span class="timeline-date">March 2019 – May 2024 (5 years) · Paris, France</span>
            </div>
            <p class="experience-desc">
              Structuring and steering the AI Practice in France, growing it **from 4 to 32 consultants**.
            </p>
            <ul class="experience-bullets">
              <li>AI projects for a major energy player: NLP (LegalBERT), risk intelligence (Neo4j Knowledge Graph), Knowledge Mining</li>
              <li>GenAI project for the **International Criminal Court**: RAG for detecting factual inconsistencies</li>
              <li>Development of accelerators: MLOps Accelerator, Prompt Injection Tests, Swarm Portfolio Optimizer</li>
              <li>Prompt engineering and AI training for large enterprise accounts (energy, insurance)</li>
            </ul>
            <div class="stack-block">
              <span class="monospace-label stack-label">Tech Stack:</span>
              <p class="stack-text">Microsoft Azure, Azure Databricks, Azure OpenAI, Neo4j, LegalBERT, Doccano</p>
            </div>
          </div>
        </div>

        <!-- Capgemini -->
        <div class="timeline-entry">
          <div class="timeline-logo">
            <img src="/assets/logos/capgemini.png" alt="Capgemini" class="company-logo" />
          </div>
          <div class="timeline-content">
            <h3 class="experience-title">Senior Data Scientist</h3>
            <div class="experience-meta">
              <strong>Capgemini</strong> <em>(Insights & Data Service)</em> · <span class="timeline-date">September 2016 – February 2019 · Suresnes (92), France</span>
            </div>
            <p class="experience-desc">
              Conception and deployment of AI solutions for fraud detection and industrial innovation.
            </p>
            <ul class="experience-bullets">
              <li><strong>CNAF</strong>: detecting suspicious logins (Neo4j graph), overpayment prediction (Bayesian networks, Spark clustering)</li>
              <li><strong>French Customs</strong>: detecting anomalies on goods declarations, benchmark of approximate search</li>
              <li><strong>Research Tax Credit (CIR) projects</strong> (Lead Data Scientist): aeronautical anomaly detection, portfolio optimization using Swarm Intelligence (MOPSO), industrial predictive maintenance</li>
              <li>Contribution to Research Tax Credit (CIR) objectives — **achieved two consecutive years**</li>
            </ul>
            <div class="stack-block">
              <span class="monospace-label stack-label">Tech Stack:</span>
              <p class="stack-text">R / sparklyr / Shiny, H2O, Spark, Hadoop, Neo4j</p>
            </div>
          </div>
        </div>

        <!-- Musicovery -->
        <div class="timeline-entry">
          <div class="timeline-logo">
            <img src="/assets/logos/musicovery.png" alt="Musicovery" class="company-logo" />
          </div>
          <div class="timeline-content">
            <h3 class="experience-title">Data Scientist & Big Data Consultant</h3>
            <div class="experience-meta">
              <strong>Musicovery</strong> · <span class="timeline-date">April 2014 – August 2016 · Paris, France</span>
            </div>
            <p class="experience-desc">
              Freelance mission for a music streaming service — machine learning applied to music recommendation.
            </p>
            <ul class="experience-bullets">
              <li>User behavioral segmentation (clustering, music discovery variables)</li>
              <li>Neo4j Knowledge Graph + Java API: high-performance solution for real-time recommendation</li>
              <li>Formalization of A/B testing (frequentist and Bayesian approaches)</li>
            </ul>
            <div class="stack-block">
              <span class="monospace-label stack-label">Tech Stack:</span>
              <p class="stack-text">AWS EC2, Hadoop, Spark, R, Shiny, Neo4j</p>
            </div>
          </div>
        </div>

        <!-- Telecom Engineer -->
        <div class="timeline-entry">
          <div class="timeline-logo logo-grid">
            <img src="/assets/logos/nokia.png" alt="Nokia" class="company-logo" />
            <img src="/assets/logos/nortel.png" alt="Nortel" class="company-logo" />
            <img src="/assets/logos/anite.png" alt="Anite" class="company-logo" />
            <img src="/assets/logos/steria.png" alt="Steria" class="company-logo" />
          </div>
          <div class="timeline-content">
            <h3 class="experience-title">Telecommunications Engineer</h3>
            <div class="experience-meta">
              <strong>Nokia · Nortel · Anite · NET2S · Steria</strong> · <span class="timeline-date">October 1998 – September 2013 (15 years) · Paris Region & Toulouse, France</span>
            </div>
            <p class="experience-desc">
              Fifteen years of network engineering in Europe's most demanding environments — before data, physical signals.
            </p>
            <ul class="experience-bullets">
              <li><strong>Nokia</strong> <em>(2008–2013)</em> — Senior Network Architect: design of the testbed that won the **Free Mobile** RFP; pre-sales for key accounts in Europe</li>
              <li><strong>Nortel</strong> <em>(2004–2008)</em> — VoIP & GSM-R Engineer: introduction of **GSM-Railways technology in France**; technical specifications for switch and subscriber database</li>
              <li><strong>Anite / Delta Partners</strong> <em>(2001–2003)</em> — Pre-sales: network planning software suite, successful sales to British Telecom and Alcatel</li>
              <li><strong>NET2S / Steria</strong> <em>(1998–2001)</em> — Certified GSM/2G Trainer (French, English, Spanish); integration of network performance management platforms</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Education Section -->
  <section class="section section-education">
    <div class="container education-container">
      <h2 class="section-title text-glow">Education</h2>
      <div class="table-container glow-card">
        <table class="formation-table">
          <thead>
            <tr>
              <th style="width: 15%;">Year</th>
              <th>Degree / Program</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>2004</strong></td>
              <td>
                <strong>M.S. in Image and Signal Processing (DEA)</strong> — ENSEA, Cergy, France
                <br /><span class="table-subtext">Neural networks, Bayesian networks, Information theory.</span>
              </td>
            </tr>
            <tr>
              <td><strong>2014</strong></td>
              <td>
                <strong>Data Science & Big Data Professional Certification</strong> — CNAM Paris, France
                <br /><span class="table-subtext">Cloudera Certifications (Hadoop Developer & Admin) & Coursera MOOCs.</span>
              </td>
            </tr>
            <tr>
              <td><strong>1998</strong></td>
              <td>
                <strong>M.S. in New Technologies and Decision Support (DESS)</strong> — Université de la Méditerranée, Marseille, France
              </td>
            </tr>
            <tr>
              <td><strong>1997</strong></td>
              <td>
                <strong>B.S. in Telecommunication Systems and Computer Networks (Maîtrise)</strong> — Université Toulouse III, France
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Languages Section -->
  <section class="section section-languages">
    <div class="container languages-container glow-card text-center">
      <h2 class="section-title text-glow" style="margin-bottom: 1rem;">Languages</h2>
      <p class="languages-text">
        <strong>Trilingual</strong> — French (fluent) · English (fluent) · Spanish (native language)
      </p>
    </div>
  </section>

  <!-- Footer CTA -->
  <section class="section section-cv-cta">
    <div class="container text-center">
      <p class="cv-cta-text">
        <em>Full CV available upon request — <a href="mailto:bguarisma@qognito.io" class="cv-email">bguarisma@qognito.io</a></em>
      </p>
    </div>
  </section>
</Layout>

<style>
  /* Layout Styles */
  .section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }
  
  /* Intro Section */
  .section-intro {
    padding-top: 6rem;
    padding-bottom: 2rem;
  }
  .intro-container {
    max-width: 850px;
    text-align: left;
  }
  .intro-flex {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
  }
  .intro-text {
    flex: 1;
  }
  .intro-photo-wrapper {
    flex-shrink: 0;
  }
  .profile-photo {
    width: 150px;
    height: 150px;
    object-fit: cover;
    border-radius: 12px;
    border: 2px solid var(--color-primary);
    box-shadow: 0 0 15px rgba(var(--color-primary-rgb), 0.2);
    transition: all 0.3s ease;
  }
  .profile-photo:hover {
    transform: scale(1.03);
    box-shadow: 0 0 20px rgba(var(--color-primary-rgb), 0.4);
    border-color: #FFFFFF;
  }
  .intro-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
  }
  .intro-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  /* Experience Section & Timeline */
  .experience-container {
    max-width: 900px;
  }
  
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 2rem;
  }
  
  .timeline-entry {
    display: flex;
    gap: 2rem;
    padding: 2rem;
    border-left: 3px solid var(--color-primary);
    border-radius: 0 8px 8px 0;
    background: var(--color-bg-card);
    border-top: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    align-items: flex-start;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .timeline-entry:hover {
    transform: translateY(-2px);
    border-color: rgba(var(--color-primary-rgb), 0.4);
    box-shadow: 
      0 10px 30px -10px rgba(0, 0, 0, 0.5),
      0 0 15px rgba(var(--color-primary-rgb), 0.1);
  }
  
  .timeline-logo {
    flex-shrink: 0;
    width: 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    padding-top: 0.25rem;
  }
  
  .logo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    width: 110px;
  }

  .company-logo {
    display: block;
    max-width: 100%;
    max-height: 45px;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }
  
  .timeline-entry:hover .company-logo {
    opacity: 1;
  }
  
  .timeline-content {
    flex: 1;
    min-width: 0;
  }
  
  .experience-title {
    font-size: 1.35rem;
    color: #FFFFFF;
    margin-bottom: 0.25rem;
  }
  
  .experience-meta {
    margin-bottom: 1rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }
  
  .experience-meta strong {
    color: #FFFFFF;
  }
  
  .timeline-date {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-primary);
    letter-spacing: 0.02em;
  }
  
  .experience-desc {
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }
  
  .mission-block {
    background: rgba(10, 22, 40, 0.4);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.25rem;
  }
  
  .mission-title {
    display: block;
    color: #FFFFFF;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }
  
  .mission-subtitle {
    display: block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 1rem;
  }
  
  .experience-bullets {
    list-style-type: none;
    padding-left: 0;
    margin: 0;
  }
  
  .experience-bullets li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  
  .experience-bullets li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-primary);
  }
  
  .experience-bullets li strong {
    color: #FFFFFF;
  }
  
  .stack-block {
    margin-top: 1rem;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .stack-label {
    margin-bottom: 0;
    font-size: 0.75rem;
    background: rgba(212, 133, 15, 0.1);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: 1px solid rgba(212, 133, 15, 0.2);
  }
  
  .stack-text {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: #FFFFFF;
    margin-bottom: 0;
  }

  /* Education Section & Table */
  .education-container {
    max-width: 900px;
  }
  
  .table-container {
    overflow-x: auto;
    padding: 0 !important;
  }
  
  .formation-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 0.95rem;
  }
  
  .formation-table th, .formation-table td {
    padding: 1.25rem 1.5rem;
  }
  
  .formation-table th {
    background-color: rgba(15, 32, 53, 0.6);
    color: #FFFFFF;
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 0.95rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .formation-table td {
    border-bottom: 1px solid rgba(30, 41, 59, 0.5);
    color: var(--color-text-muted);
    line-height: 1.6;
  }
  
  .formation-table tr:last-child td {
    border-bottom: none;
  }
  
  .formation-table td strong {
    color: #FFFFFF;
  }
  
  .table-subtext {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    display: inline-block;
    margin-top: 0.25rem;
  }

  /* Languages Section */
  .languages-container {
    max-width: 900px;
    padding: 2rem;
  }
  
  .languages-text {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }
  
  .languages-text strong {
    color: #FFFFFF;
  }

  /* CV CTA Section */
  .section-cv-cta {
    padding-top: 1rem;
    padding-bottom: 4rem;
  }
  
  .cv-cta-text {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }
  
  .cv-email {
    color: var(--color-primary);
    border-bottom: 1px dashed var(--color-primary);
  }
  
  .cv-email:hover {
    color: #FFFFFF;
    border-bottom-color: #FFFFFF;
  }

  .text-center {
    text-align: center;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .intro-flex {
      flex-direction: column-reverse;
      gap: 1.5rem;
    }
    
    .profile-photo {
      width: 130px;
      height: 130px;
    }
    
    .intro-title {
      font-size: 2.25rem;
    }
    
    .timeline-entry {
      flex-direction: column;
      gap: 1.5rem;
      padding: 1.5rem;
    }
    
    .timeline-logo {
      width: auto;
      align-items: flex-start;
    }
    
    .logo-grid {
      grid-template-columns: repeat(4, 1fr);
      width: 100%;
      max-width: 240px;
    }
    
    .company-logo {
      max-height: 35px;
    }
    
    .formation-table th, .formation-table td {
      padding: 1rem;
    }
  }
</style>